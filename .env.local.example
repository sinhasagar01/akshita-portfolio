# Copy this file to .env.local and fill in real values before running locally.
# Never commit .env.local to git.

# Production origin, no trailing slash. Used for metadataBase in app/layout.tsx.
NEXT_PUBLIC_SITE_URL=https://www.akshitas.com

# Keystatic writes content to the local filesystem in development.
# Switch to github mode when wiring up production CMS writes.
# KEYSTATIC_GITHUB_CLIENT_ID=
# KEYSTATIC_GITHUB_CLIENT_SECRET=
# KEYSTATIC_SECRET=
